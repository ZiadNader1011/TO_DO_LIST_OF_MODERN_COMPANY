generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id               String             @id @default(cuid())
  name             String
  role             String
  avatarSeed       Int                @default(0)
  
  // العلاقات الصحيحة
  assignedTasks    Task[]             @relation("AssignedTasks")
  createdTasks     Task[]             @relation("CreatedTasks")
  submittedReports InspectionReport[]
}

enum Priority {
  urgent
  medium
  low
}

enum TaskStatus {
  pending
  acknowledged
  completed
}

model Task {
  id          String     @id @default(cuid())
  ref         String
  title       String
  description String
  priority    Priority
  status      TaskStatus
  
  assignee    Employee?  @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: Cascade)
  assigneeId  String?
  
  createdBy   Employee?  @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  createdById String?
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dueDate     DateTime?
}

model InspectionReport {
  id                       String   @id @default(cuid())
  jobNumber                String
  date                    DateTime
  supervisor               String
  arrivalTime              String
  departureTime            String
  stationName              String
  stationManager           String
  orderSummary             String
  submittedAt              DateTime @default(now())
  updatedAt                DateTime @updatedAt

  productQuality           String?
  productQualityNotes      String?
  caliper                  String?
  caliperNotes             String?
  washing                  String?
  washingNotes             String?
  packingMaterial          String?
  packingMaterialNotes     String?
  temperatureTreatment     String?
  temperatureC             String?
  temperatureNotes         String?
  packingWeightSize        String?
  packingWeightSizeNotes   String?
  palletsCheck             String?
  palletsCheckNotes        String?
  palletsConditionType     String?
  palletsConditionStrength String?
  palletsConditionNotes    String?
  palletsPreparedWeight    String?
  palletsPreparedWrapping  String?
  palletsPreparedNotes     String?
  fitting                  String?
  fittingNotes             String?
  storageCondition         String?
  loadingStart             String?
  loadingEnd               String?
  containerWashed          String?
  containerWashedNotes     String?
  testingTempCondition     String?
  finalLoadingDetails      String?
  inspectorName            String
  signature                String

  submittedById            String
  submittedBy              Employee @relation(fields: [submittedById], references: [id], onDelete: Cascade)
}